<Window x:Class="HospitexDPP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HospitexDPP.ViewModels"
        xmlns:views="clr-namespace:HospitexDPP.Views"
        xmlns:h="clr-namespace:HospitexDPP.Helpers"
        Title="Hospitex DPP" Height="768" Width="1024"
        MinHeight="768" MinWidth="1024"
        Icon="dpp.ico"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdminViewModel}">
            <views:AdminView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BrandViewModel}">
            <views:BrandView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierViewModel}">
            <views:SupplierView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar replacing menu bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,6">
            <DockPanel>
                <!-- Right: settings button -->
                <Button DockPanel.Dock="Right" Click="SettingsButton_Click"
                        Background="Transparent" BorderThickness="0"
                        Padding="8,4" Cursor="Hand" VerticalAlignment="Center">
                    <TextBlock Text="&#x2699;" FontSize="18" Foreground="{DynamicResource TextSecondaryBrush}" />
                </Button>

                <!-- Left: logo + app name -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/DPP-2.png" Width="24" Height="24" Stretch="Uniform" />
                    <TextBlock Text="Hospitex DPP" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0" />
                </StackPanel>

                <!-- Center: role switcher (only visible in dual-role mode) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsDualRole, Converter={StaticResource BoolToVisibility}}">
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="2" SnapsToDevicePixels="True">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding SwitchToBrandCommand}"
                                    Content="{Binding BrandLabel}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource RoleSwitchButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBrandActive}" Value="True">
                                                <Setter Property="Tag" Value="Active" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Command="{Binding SwitchToSupplierCommand}"
                                    Content="{Binding SupplierLabel}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource RoleSwitchButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSupplierActive}" Value="True">
                                                <Setter Property="Tag" Value="Active" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <ContentControl Content="{Binding CurrentView}" />
    </DockPanel>
</Window>
