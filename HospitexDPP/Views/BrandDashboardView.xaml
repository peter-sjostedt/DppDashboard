<UserControl x:Class="HospitexDPP.Views.BrandDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:HospitexDPP.Helpers">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,32">
            <StackPanel MaxWidth="900" HorizontalAlignment="Left">
                <!-- Welcome -->
                <TextBlock Text="{Binding WelcomeText}" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,24" />

                <!-- Loading indicator -->
                <TextBlock Text="..." FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,16"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />

                <!-- Action cards grid -->
                <ItemsControl ItemsSource="{Binding Cards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding NavigateCommand}" Cursor="Hand"
                                    Margin="0,0,16,16" Width="260" MinHeight="140"
                                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CardBorder"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" CornerRadius="8"
                                                Padding="20,16">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter TargetName="CardBorder" Property="Background" Value="#F0F4FF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="{Binding Icon}" FontSize="20"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- No actions message -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,40,0,0"
                            Visibility="{Binding ShowNoActions, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding NoActionsText}" FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text=" &#x2714;" FontSize="16"
                               Foreground="{DynamicResource SuccessBrush}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
